{
  "schema": 2,
  "permissions": ["tools.invoke", "storage.read", "storage.write"],
  "required_executas": [
    {
      "tool_id": "__TOOL_ID__"
    }
  ],
  "tags": ["__SLUG__"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "__SLUG__",
        "default": true,
        "default_size": { "w": 480, "h": 360 },
        "min_size": { "w": 320, "h": 240 }
      }
    ],
    "host_api": {
      "tools": ["__TOOL_ID__"],
      "storage": ["get", "set"],
      "window": ["set_title", "ready"]
    },
    "csp_overrides": {},
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": ["fixtures/*.jsonl"],
    "seed_storage": {},
    "user_id": 1
  }
}
