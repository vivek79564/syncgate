{
  "name": "@anna-ai/cli",
  "version": "0.1.30",
  "description": "Anna App developer CLI: scaffold, validate, harness (Phase 2 MVP: init + validate).",
  "license": "MIT",
  "type": "module",
  "bin": {
    "anna-app": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./test": {
      "types": "./dist/test/index.d.ts",
      "import": "./dist/test/index.js"
    }
  },
  "files": [
    "dist/",
    "templates/",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "check:runtime-pin": "node scripts/check-runtime-pin.mjs",
    "check:sdk-pin": "node scripts/check-sdk-pin.mjs",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm build && node scripts/check-runtime-pin.mjs && node scripts/check-sdk-pin.mjs"
  },
  "dependencies": {
    "@anna-ai/app-runtime": "^0.8.0",
    "@anna-ai/app-schema": "^0.10.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "smol-toml": "^1.6.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsdown": "^0.9.6",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
