{
  "$defs": {
    "AgentFixedSubmodeSpec": {
      "additionalProperties": false,
      "properties": {
        "client_ids": {
          "items": {
            "type": "string"
          },
          "title": "Client Ids",
          "type": "array"
        }
      },
      "title": "AgentFixedSubmodeSpec",
      "type": "object"
    },
    "AgentHostApiSpec": {
      "additionalProperties": false,
      "description": "Top-level grant for the ``agent`` host-API namespace.",
      "properties": {
        "session": {
          "$ref": "#/$defs/AgentSessionSubmodeSpec"
        },
        "tools": {
          "items": {
            "type": "string"
          },
          "title": "Tools",
          "type": "array"
        }
      },
      "title": "AgentHostApiSpec",
      "type": "object"
    },
    "AgentSessionSubmodeSpec": {
      "additionalProperties": false,
      "description": "Per-submode toggle for ``host_api.agent.session``.\n\nSee ``docs/design/app-llm-and-agent-access.md`` §6.1.",
      "properties": {
        "auto": {
          "default": false,
          "title": "Auto",
          "type": "boolean"
        },
        "fixed": {
          "anyOf": [
            {
              "$ref": "#/$defs/AgentFixedSubmodeSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "AgentSessionSubmodeSpec",
      "type": "object"
    },
    "AppDevConfig": {
      "additionalProperties": true,
      "description": "Optional ``manifest.dev`` block — local-harness-only configuration.\n\nProduction dispatcher ignores this field at runtime (it is declared here\nso ``extra=\"forbid\"`` doesn't reject it). ``anna-app publish`` SHOULD\nstrip ``dev`` from the manifest before upload; mirroring nexus's\nhistorical \"drop unknown keys\" behaviour.\n\nSee design doc §8 for field semantics. All fields are intentionally loose\n(`Any`) so the harness can evolve independently from the wire schema.",
      "properties": {
        "fixtures": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Glob patterns for fixture JSONL files relative to manifest dir.",
          "title": "Fixtures"
        },
        "mocks": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Per-(ns,method) static response mocks, keyed by 'ns.method'.",
          "title": "Mocks"
        },
        "seed_storage": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Initial runtime_state for `anna-app dev` sessions.",
          "title": "Seed Storage"
        },
        "user_id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Override the default harness user_id (default: 1).",
          "title": "User Id"
        }
      },
      "title": "AppDevConfig",
      "type": "object"
    },
    "ManifestExecutaRef": {
      "properties": {
        "min_version": {
          "anyOf": [
            {
              "maxLength": 40,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Min Version"
        },
        "tool_id": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Tool Id",
          "type": "string"
        },
        "version": {
          "anyOf": [
            {
              "maxLength": 40,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Executa snapshot version to pin. Omit or use 'latest' to auto-freeze the current Executa state at publish time.",
          "title": "Version"
        }
      },
      "required": [
        "tool_id"
      ],
      "title": "ManifestExecutaRef",
      "type": "object"
    },
    "UiBundleSection": {
      "additionalProperties": false,
      "properties": {
        "entry": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Entry",
          "type": "string"
        },
        "external_origins": {
          "items": {
            "type": "string"
          },
          "title": "External Origins",
          "type": "array"
        },
        "format": {
          "default": "static-spa",
          "maxLength": 20,
          "title": "Format",
          "type": "string"
        }
      },
      "required": [
        "entry"
      ],
      "title": "UiBundleSection",
      "type": "object"
    },
    "UiHostApiSpec": {
      "additionalProperties": false,
      "properties": {
        "agent": {
          "$ref": "#/$defs/AgentHostApiSpec"
        },
        "artifact": {
          "items": {
            "type": "string"
          },
          "title": "Artifact",
          "type": "array"
        },
        "chat": {
          "items": {
            "type": "string"
          },
          "title": "Chat",
          "type": "array"
        },
        "files": {
          "items": {
            "type": "string"
          },
          "title": "Files",
          "type": "array"
        },
        "fs": {
          "items": {
            "type": "string"
          },
          "title": "Fs",
          "type": "array"
        },
        "image": {
          "items": {
            "type": "string"
          },
          "title": "Image",
          "type": "array"
        },
        "llm": {
          "items": {
            "type": "string"
          },
          "title": "Llm",
          "type": "array"
        },
        "prefs": {
          "items": {
            "type": "string"
          },
          "title": "Prefs",
          "type": "array"
        },
        "storage": {
          "items": {
            "type": "string"
          },
          "title": "Storage",
          "type": "array"
        },
        "tools": {
          "items": {
            "type": "string"
          },
          "title": "Tools",
          "type": "array"
        },
        "upload": {
          "items": {
            "type": "string"
          },
          "title": "Upload",
          "type": "array"
        },
        "window": {
          "items": {
            "type": "string"
          },
          "title": "Window",
          "type": "array"
        }
      },
      "title": "UiHostApiSpec",
      "type": "object"
    },
    "UiManifestSection": {
      "additionalProperties": false,
      "properties": {
        "bundle": {
          "$ref": "#/$defs/UiBundleSection"
        },
        "csp_overrides": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Csp Overrides",
          "type": "object"
        },
        "host_api": {
          "$ref": "#/$defs/UiHostApiSpec"
        },
        "state_merge": {
          "default": "last_writer_wins",
          "maxLength": 20,
          "title": "State Merge",
          "type": "string"
        },
        "views": {
          "items": {
            "$ref": "#/$defs/UiViewSpec"
          },
          "title": "Views",
          "type": "array"
        }
      },
      "required": [
        "bundle"
      ],
      "title": "UiManifestSection",
      "type": "object"
    },
    "UiSize": {
      "additionalProperties": false,
      "properties": {
        "h": {
          "maximum": 4096,
          "minimum": 120,
          "title": "H",
          "type": "integer"
        },
        "w": {
          "maximum": 4096,
          "minimum": 120,
          "title": "W",
          "type": "integer"
        }
      },
      "required": [
        "w",
        "h"
      ],
      "title": "UiSize",
      "type": "object"
    },
    "UiViewSpec": {
      "additionalProperties": false,
      "properties": {
        "default": {
          "default": false,
          "title": "Default",
          "type": "boolean"
        },
        "default_size": {
          "anyOf": [
            {
              "$ref": "#/$defs/UiSize"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "entry": {
          "anyOf": [
            {
              "maxLength": 300,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Entry"
        },
        "icon": {
          "anyOf": [
            {
              "maxLength": 200,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Icon"
        },
        "max_size": {
          "anyOf": [
            {
              "$ref": "#/$defs/UiSize"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "min_size": {
          "anyOf": [
            {
              "$ref": "#/$defs/UiSize"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "movable": {
          "default": true,
          "title": "Movable",
          "type": "boolean"
        },
        "name": {
          "maxLength": 40,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "resizable": {
          "default": true,
          "title": "Resizable",
          "type": "boolean"
        },
        "single_instance": {
          "default": false,
          "title": "Single Instance",
          "type": "boolean"
        },
        "summary_template": {
          "anyOf": [
            {
              "maxLength": 400,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Summary Template"
        },
        "title": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "name",
        "title"
      ],
      "title": "UiViewSpec",
      "type": "object"
    }
  },
  "$id": "https://schemas.anna.partners/app-manifest.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "App Manifest schema (stored in ``anna_app_versions.manifest``).\n\nAdding a field here MUST be coordinated with ``anna-app-schema`` JSON\nSchema bundle and ``DISPATCHER_VERSION`` in `versions.py`.",
  "properties": {
    "dev": {
      "anyOf": [
        {
          "$ref": "#/$defs/AppDevConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "host_capabilities": {
      "items": {
        "type": "string"
      },
      "title": "Host Capabilities",
      "type": "array"
    },
    "optional_executas": {
      "items": {
        "$ref": "#/$defs/ManifestExecutaRef"
      },
      "title": "Optional Executas",
      "type": "array"
    },
    "permissions": {
      "items": {
        "type": "string"
      },
      "title": "Permissions",
      "type": "array"
    },
    "required_executas": {
      "items": {
        "$ref": "#/$defs/ManifestExecutaRef"
      },
      "title": "Required Executas",
      "type": "array"
    },
    "schema": {
      "default": 1,
      "maximum": 2,
      "minimum": 1,
      "title": "Schema",
      "type": "integer"
    },
    "system_prompt_addendum": {
      "anyOf": [
        {
          "maxLength": 4000,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "System Prompt Addendum"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "ui": {
      "anyOf": [
        {
          "$ref": "#/$defs/UiManifestSection"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "user_message_prefix_template": {
      "anyOf": [
        {
          "maxLength": 500,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "User Message Prefix Template"
    }
  },
  "title": "AppManifest",
  "type": "object"
}
