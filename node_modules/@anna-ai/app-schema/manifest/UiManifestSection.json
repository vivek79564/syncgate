{
  "$defs": {
    "AgentFixedSubmodeSpec": {
      "additionalProperties": false,
      "properties": {
        "client_ids": {
          "items": {
            "type": "string"
          },
          "title": "Client Ids",
          "type": "array"
        }
      },
      "title": "AgentFixedSubmodeSpec",
      "type": "object"
    },
    "AgentHostApiSpec": {
      "additionalProperties": false,
      "description": "Top-level grant for the ``agent`` host-API namespace.",
      "properties": {
        "session": {
          "$ref": "#/$defs/AgentSessionSubmodeSpec"
        },
        "tools": {
          "items": {
            "type": "string"
          },
          "title": "Tools",
          "type": "array"
        }
      },
      "title": "AgentHostApiSpec",
      "type": "object"
    },
    "AgentSessionSubmodeSpec": {
      "additionalProperties": false,
      "description": "Per-submode toggle for ``host_api.agent.session``.\n\nSee ``docs/design/app-llm-and-agent-access.md`` §6.1.",
      "properties": {
        "auto": {
          "default": false,
          "title": "Auto",
          "type": "boolean"
        },
        "fixed": {
          "anyOf": [
            {
              "$ref": "#/$defs/AgentFixedSubmodeSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "AgentSessionSubmodeSpec",
      "type": "object"
    },
    "UiBundleSection": {
      "additionalProperties": false,
      "properties": {
        "entry": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Entry",
          "type": "string"
        },
        "external_origins": {
          "items": {
            "type": "string"
          },
          "title": "External Origins",
          "type": "array"
        },
        "format": {
          "default": "static-spa",
          "maxLength": 20,
          "title": "Format",
          "type": "string"
        }
      },
      "required": [
        "entry"
      ],
      "title": "UiBundleSection",
      "type": "object"
    },
    "UiHostApiSpec": {
      "additionalProperties": false,
      "properties": {
        "agent": {
          "$ref": "#/$defs/AgentHostApiSpec"
        },
        "artifact": {
          "items": {
            "type": "string"
          },
          "title": "Artifact",
          "type": "array"
        },
        "chat": {
          "items": {
            "type": "string"
          },
          "title": "Chat",
          "type": "array"
        },
        "files": {
          "items": {
            "type": "string"
          },
          "title": "Files",
          "type": "array"
        },
        "fs": {
          "items": {
            "type": "string"
          },
          "title": "Fs",
          "type": "array"
        },
        "image": {
          "items": {
            "type": "string"
          },
          "title": "Image",
          "type": "array"
        },
        "llm": {
          "items": {
            "type": "string"
          },
          "title": "Llm",
          "type": "array"
        },
        "prefs": {
          "items": {
            "type": "string"
          },
          "title": "Prefs",
          "type": "array"
        },
        "storage": {
          "items": {
            "type": "string"
          },
          "title": "Storage",
          "type": "array"
        },
        "tools": {
          "items": {
            "type": "string"
          },
          "title": "Tools",
          "type": "array"
        },
        "upload": {
          "items": {
            "type": "string"
          },
          "title": "Upload",
          "type": "array"
        },
        "window": {
          "items": {
            "type": "string"
          },
          "title": "Window",
          "type": "array"
        }
      },
      "title": "UiHostApiSpec",
      "type": "object"
    },
    "UiSize": {
      "additionalProperties": false,
      "properties": {
        "h": {
          "maximum": 4096,
          "minimum": 120,
          "title": "H",
          "type": "integer"
        },
        "w": {
          "maximum": 4096,
          "minimum": 120,
          "title": "W",
          "type": "integer"
        }
      },
      "required": [
        "w",
        "h"
      ],
      "title": "UiSize",
      "type": "object"
    },
    "UiViewSpec": {
      "additionalProperties": false,
      "properties": {
        "default": {
          "default": false,
          "title": "Default",
          "type": "boolean"
        },
        "default_size": {
          "anyOf": [
            {
              "$ref": "#/$defs/UiSize"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "entry": {
          "anyOf": [
            {
              "maxLength": 300,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Entry"
        },
        "icon": {
          "anyOf": [
            {
              "maxLength": 200,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Icon"
        },
        "max_size": {
          "anyOf": [
            {
              "$ref": "#/$defs/UiSize"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "min_size": {
          "anyOf": [
            {
              "$ref": "#/$defs/UiSize"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "movable": {
          "default": true,
          "title": "Movable",
          "type": "boolean"
        },
        "name": {
          "maxLength": 40,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "resizable": {
          "default": true,
          "title": "Resizable",
          "type": "boolean"
        },
        "single_instance": {
          "default": false,
          "title": "Single Instance",
          "type": "boolean"
        },
        "summary_template": {
          "anyOf": [
            {
              "maxLength": 400,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Summary Template"
        },
        "title": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "name",
        "title"
      ],
      "title": "UiViewSpec",
      "type": "object"
    }
  },
  "$id": "https://schemas.anna.partners/ui-manifest-section.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "bundle": {
      "$ref": "#/$defs/UiBundleSection"
    },
    "csp_overrides": {
      "additionalProperties": {
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "title": "Csp Overrides",
      "type": "object"
    },
    "host_api": {
      "$ref": "#/$defs/UiHostApiSpec"
    },
    "state_merge": {
      "default": "last_writer_wins",
      "maxLength": 20,
      "title": "State Merge",
      "type": "string"
    },
    "views": {
      "items": {
        "$ref": "#/$defs/UiViewSpec"
      },
      "title": "Views",
      "type": "array"
    }
  },
  "required": [
    "bundle"
  ],
  "title": "UiManifestSection",
  "type": "object"
}
